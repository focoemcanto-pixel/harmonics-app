# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Resend (email)
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL="Harmonics <convites@yourdomain.com>"

# URL pública do app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Contratos (Google Docs/Drive)
CONTRACT_TEMPLATE_DOC_ID=your_google_doc_template_id
CONTRACTS_DRIVE_FOLDER_ID=your_google_drive_root_folder_id
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_OAUTH_REDIRECT_URI=https://your-app.com/api/google/oauth/callback
GOOGLE_OAUTH_REFRESH_TOKEN=your_google_oauth_refresh_token

