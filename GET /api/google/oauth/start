import { google } from 'googleapis';
import { supabase } from './supabaseClient'; // Importe sua instância do supabase

// Configuração do cliente OAuth2
const oauth2Client = new google.auth.OAuth2(
  process.env.GOOGLE_OAUTH_CLIENT_ID,
  process.env.GOOGLE_OAUTH_CLIENT_SECRET,
  process.env.GOOGLE_OAUTH_REDIRECT_URI
);

// Função para revogar o token
async function revokeToken(refreshToken) {
  try {
    // Revoga o token de atualização
    await oauth2Client.revokeToken(refreshToken);
    console.log('Token revogado com sucesso!');
  } catch (error) {
    console.error('Erro ao revogar o token:', error);
  }
}

// Função para salvar os tokens no banco de dados
async function saveTokensInDatabase(tokens, userId) {
  try {
    const { data, error } = await supabase
      .from('google_oauth_credentials')
      .upsert([
        {
          user_id: userId,
          refresh_token: tokens.refresh_token,
          access_token: tokens.access_token,
          credentials: JSON.stringify(tokens), // Garantindo que as credenciais estejam corretamente serializadas
        },
      ], { onConflict: ['user_id'] }); // Usando a chave única user_id para resolver conflitos

    if (error) {
      throw new Error('Erro ao salvar tokens no banco');
    }
    console.log('Tokens salvos com sucesso');
  } catch (error) {
    console.error('Erro ao salvar tokens no banco:', error);
  }
}

// Handler para a autenticação
export async function handler(req, res) {
  const { userId, code } = req.query; // Código de autorização do Google e userId

  if (!code) {
    return res.status(400).send('Código de autorização ausente');
  }

  try {
    // Troca o código pelo access_token e refresh_token
    const { tokens } = await oauth2Client.getToken(code);
    oauth2Client.setCredentials(tokens);  // Configura as credenciais do Google

    // Persistir tokens no banco de dados
    await saveTokensInDatabase(tokens, userId);

    // Redirecionar após sucesso
    res.redirect('/success');
  } catch (error) {
    console.error('Erro ao trocar o código por tokens:', error);
    res.status(500).send('Erro ao autenticar');
  }
}

// Função para lidar com a reautenticação do Google OAuth
export async function forceReauth(req, res) {
  const { userId } = req.query; // userId do usuário

  // Desabilita a credencial antiga no banco
  await supabase
    .from('google_oauth_credentials')
    .update({ status: 'expired' })
    .eq('user_id', userId);

  // Gera novo URL com prompt=consent
  const authUrl = oauth2Client.generateAuthUrl({
    access_type: 'offline',
    prompt: 'consent',  // Força Google a sempre retornar refresh_token
    scope: [
      'https://www.googleapis.com/auth/drive',
      'https://www.googleapis.com/auth/documents'
    ],
    state: Math.random().toString(36).slice(2), // Gerar estado aleatório para proteção contra CSRF
  });

  return res.json({ reauthUrl: authUrl });
}
