{
  "name": "harmonics-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && rm -rf .next/cache && rm -rf cache",
    "build:cloudflare": "next build && rm -rf .next/cache && rm -rf cache && npx @opennextjs/cloudflare build",
    "deploy": "npm run build:cloudflare && npx wrangler pages deploy .open-next/cloudflare",
    "preview": "wrangler pages dev .open-next/cloudflare",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.3",
    "googleapis": "^171.4.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.17.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.65.0"
  }
}